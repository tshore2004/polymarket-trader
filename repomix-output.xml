  <script>
    function app() {
      return {
        activeTab: 'dashboard',
        state: {
          state: 'idle', balance: null,
          signal_count: 0, news_signal_count: 0, volume_signal_count: 0,
          trader_count: 0, consensus_count: 0,
          last_scan_at: null, scan_duration_s: null,
          markets_loaded: 0, error: null, scan_count: 0,
          scan_stage: '', scan_progress: 0, scan_mode: 'today',
        },
        signals: [],
        traders: [],
        consensuses: [],
        picks: [],
        sidebarPicks: [],
        picksFilter: 'all',
        categoryFilter: 'all',
        subcatFilter: 'all',
        scanTriggering: false,
        loadingSignals: false,
        loadingLeaderboard: false,
        loadingPicks: false,

        // Picks resolving TODAY (within 24h), sorted by daily_score
        get todaysPicks() {
          return this.picks
            .filter(p => p.time_category === 'tonight')
            .sort((a, b) => (b.daily_score || 0) - (a.daily_score || 0))
            .slice(0, 5);
        },

        get filteredPicks() {
          let result = this.picks;
          if (this.categoryFilter === 'live') {
            result = result.filter(p => p.time_category === 'tonight');
          } else if (this.categoryFilter !== 'all') {
            result = result.filter(p => p.category === this.categoryFilter);
          }
          if (this.subcatFilter !== 'all') {
            result = result.filter(p => p.subcategory === this.subcatFilter);
          }
          if (this.picksFilter !== 'all') {
            result = result.filter(p => p.time_category === this.picksFilter);
          }
          return result;
        },

        // All sport subcategories that have at least one pick
        get availableSportSubcats() {
          const sportPicks = this.picks.filter(p => p.category === 'sports' && p.subcategory);
          const subcats = [...new Set(sportPicks.map(p => p.subcategory))];
          return subcats.sort();
        },

        picksFilterCount(cat) {
          return this.picks.filter(p => p.time_category === cat).length;
        },
        categoryCount(cat) {
          if (cat === 'live') return this.picks.filter(p => p.time_category === 'tonight').length;
          return this.picks.filter(p => p.category === cat).length;
        },

        async init() {
          await this.fetchState();
          await this.fetchSignals();
          await this.fetchSidebarPicks();
          setInterval(() => this.pollState(), 5000);
        },

        async pollState() {
          const prev = this.state.scan_count;
          await this.fetchState();
          if (this.state.scan_count > prev) {
            await Promise.all([
              this.fetchSignals(),
              this.fetchSidebarPicks(),
              this.activeTab === 'leaderboard' ? this.fetchLeaderboard() : Promise.resolve(),
              this.activeTab === 'picks' ? this.fetchPicks() : Promise.resolve(),
            ]);
          }
        },

        async fetchState() {
          try {
            const r = await fetch('/api/state');
            this.state = await r.json();
          } catch (_) {}
        },

        async fetchSidebarPicks() {
          try {
            const r = await fetch('/api/picks');
            const d = await r.json();
            this.sidebarPicks = (d || [])
              .sort((a, b) => (b.daily_score || 0) - (a.daily_score || 0))
              .slice(0, 7);
          } catch (_) {
            this.sidebarPicks = [];
          }
        },

        async fetchSignals() {
          this.loadingSignals = true;
          try {
            const r = await fetch('/api/signals');
            this.signals = await r.json();
          } catch (_) {
            this.signals = [];
          } finally {
            this.loadingSignals = false;
          }
        },

        async fetchLeaderboard() {
          this.loadingLeaderboard = true;
          try {
            const r = await fetch('/api/leaderboard');
            const d = await r.json();
            this.traders = d.traders || [];
            this.consensuses = d.consensuses || [];
          } catch (_) {
            this.traders = [];
            this.consensuses = [];
          } finally {
            this.loadingLeaderboard = false;
          }
        },

        async fetchPicks() {
          this.loadingPicks = true;
          try {
            const r = await fetch('/api/picks');
            this.picks = await r.json() || [];
          } catch (_) {
            this.picks = [];
          } finally {
            this.loadingPicks = false;
          }
        },

        async switchTab(tab) {
          this.activeTab = tab;
          if (tab === 'leaderboard') await this.fetchLeaderboard();
          else if (tab === 'signals') await this.fetchSignals();
          else if (tab === 'picks') await this.fetchPicks();
        },

        async triggerScan() {
          this.scanTriggering = true;
          try {
            await fetch('/api/scan', { method: 'POST' });
            for (let i = 0; i < 30; i++) {
              await new Promise(r => setTimeout(r, 2000));
              await this.fetchState();
              if (this.state.state !== 'scanning') break;
            }
            await Promise.all([
              this.fetchSignals(),
              this.fetchSidebarPicks(),
              this.activeTab === 'leaderboard' ? this.fetchLeaderboard() : Promise.resolve(),
              this.activeTab === 'picks' ? this.fetchPicks() : Promise.resolve(),
            ]);
          } finally {
            this.scanTriggering = false;
          }
        },

        async refreshCurrentTab() {
          await this.fetchState();
          await this.fetchSidebarPicks();
          if (this.activeTab === 'signals') await this.fetchSignals();
          else if (this.activeTab === 'leaderboard') await this.fetchLeaderboard();
          else if (this.activeTab === 'picks') await this.fetchPicks();
          else await this.fetchSignals();
        },

        // ── Helpers ──
        confidencePct(pick) {
          const total = (pick.yes_weight || 0) + (pick.no_weight || 0);
          if (!total) return 50;
          return Math.round(Math.abs((pick.yes_weight || 0) - (pick.no_weight || 0)) / total * 100);
        },

        categoryEmoji(category, subcategory) {
          const map = {
            'nfl': '🏈', 'nba': '🏀', 'mlb': '⚾', 'nhl': '🏒',
            'soccer': '⚽', 'tennis': '🎾', 'golf': '⛳', 'ufc': '🥊',
            'esports': '🎮', 'formula-1': '🏎', 'other-sports': '🏅',
            'sports': '🏆', 'politics': '🏛', 'crypto': '🪙',
            'entertainment': '🎬', 'other': '📊',
          };
          return map[subcategory] || map[category] || '📊';
        },

        subcatEmoji(subcat) {
          const map = {
            'nfl': '🏈', 'nba': '🏀', 'mlb': '⚾', 'nhl': '🏒',
            'soccer': '⚽', 'tennis': '🎾', 'golf': '⛳', 'ufc': '🥊',
            'esports': '🎮', 'formula-1': '🏎', 'other-sports': '🏅',
          };
          return map[subcat] || '';
        },

        // ── Formatters ──
        pctFmt(v) { return (v * 100).toFixed(2) + '%'; },
        moneyFmt(v) { return '$' + v.toLocaleString(undefined, { maximumFractionDigits: 0 }); },
        timeAgo(iso) {
          if (!iso) return 'never';
          const s = Math.round((Date.now() - new Date(iso)) / 1000);
          if (s < 60) return s + 's ago';
          if (s < 3600) return Math.round(s / 60) + 'm ago';
          return Math.round(s / 3600) + 'h ago';
        },
        scoreColor(s) {
          return s >= 70 ? 'text-green-400' : s >= 45 ? 'text-yellow-400' : 'text-cyan-400';
        },
        scoreCircleClass(s) {
          if (s >= 70) return 'border-green-500 text-green-400';
          if (s >= 45) return 'border-yellow-500 text-yellow-400';
          return 'border-cyan-600 text-cyan-400';
        },
        typeBadgeClass(t) {
          if (t === 'MULTI') return 'bg-green-950 text-green-400 border border-green-800';
          if (t === 'FAIR_VALUE') return 'bg-cyan-950 text-cyan-400 border border-cyan-800';
          if (t === 'LEADERBOARD') return 'bg-blue-950 text-blue-400 border border-blue-800';
          if (t === 'NEWS') return 'bg-emerald-950 text-emerald-400 border border-emerald-800';
          if (t === 'VOLUME_SPIKE') return 'bg-yellow-950 text-yellow-400 border border-yellow-800';
          return 'bg-purple-950 text-purple-400 border border-purple-800';
        },
        sideBadgeClass(s) {
          if (s === 'YES') return 'bg-green-950 text-green-400 border border-green-800';
          if (s === 'NO') return 'bg-red-950 text-red-400 border border-red-800';
          return 'bg-gray-800 text-gray-300 border border-gray-700';
        },
        timeBadgeLabel(cat) {
          const labels = { tonight: 'Tonight', tomorrow: 'Tomorrow', this_week: 'This Week', this_month: 'This Month' };
          return labels[cat] || null;
        },
        timeBadgeClass(cat) {
          if (cat === 'tonight')    return 'bg-red-950 text-red-300 border border-red-800';
          if (cat === 'tomorrow')   return 'bg-orange-950 text-orange-300 border border-orange-800';
          if (cat === 'this_week')  return 'bg-yellow-950 text-yellow-400 border border-yellow-800';
          if (cat === 'this_month') return 'bg-blue-950 text-blue-400 border border-blue-800';
          return '';
        },
      };
    }
  </script>
  <script defer src="https://unpkg.com/alpinejs@3.14.1/dist/cdn.min.js"></script>
</body>
