# ── Private key (REQUIRED for placing orders) ────────────────────────────────
# Your wallet's raw private key — 64 hex chars, with or without 0x prefix.
# For email/iOS login: export from privy.io using the same email you use on Polymarket.
# This stays on your machine and signs orders locally — it is never sent anywhere.
POLY_PRIVATE_KEY=0x<your_64_char_hex_private_key>

# ── Funder / wallet address (REQUIRED for email/iOS login) ───────────────────
# The Polymarket proxy wallet address that holds your funds.
# = your "account ID" from Polymarket support (a 0x... address).
# Ask Polymarket support: "What is my proxy wallet / funder address?"
POLY_FUNDER=0x<your_proxy_wallet_address>

# ── API credentials (all three required) ─────────────────────────────────────
# Generated once from your private key. If you got Key ID + Secret from support,
# you still need the Passphrase — it was shown once when the key was created.
# If you lost it, generate fresh creds by running: python tests/diagnose.py
POLY_API_KEY=<your_key_id>
POLY_API_SECRET=<your_secret_key>
POLY_API_PASSPHRASE=<your_passphrase>

# ── Signature type ────────────────────────────────────────────────────────────
# 0 = EOA          — standard MetaMask wallet (pays gas)
# 1 = POLY_PROXY   — email / Google / iOS login (most common, default)
# 2 = GNOSIS_SAFE  — existing Gnosis Safe wallet
# 3 = POLY_1271    — new deposit wallet for API-only users
POLY_SIGNATURE_TYPE=1

# ── Risk settings ─────────────────────────────────────────────────────────────
MAX_BET_SIZE=25.0
MIN_BET_SIZE=5.0
SCAN_INTERVAL=60

# ── Leaderboard filters ───────────────────────────────────────────────────────
LEADERBOARD_TOP_N=20
LEADERBOARD_MIN_PROFIT=5000
LEADERBOARD_MIN_VOLUME=10000
LEADERBOARD_WINDOW=1m

# ── Scan mode ─────────────────────────────────────────────────────────────────
# today | all | leaderboard | news | volume  (can also be set interactively at startup)
SCAN_MODE=today

# ── Market category filter ─────────────────────────────────────────────────────
# Comma-separated tag slugs. Leave blank to scan ALL categories.
# Example: MARKET_TAGS_FILTER=politics,crypto
MARKET_TAGS_FILTER=

# ── News sentiment ─────────────────────────────────────────────────────────────
# Set to false to disable news-based signals entirely
NEWS_ENABLED=true
# Optional: NewsAPI.org free key for richer US news coverage (100 req/day free tier)
# Sign up at https://newsapi.org — leave blank to use free RSS feeds only
NEWS_API_KEY=
# How often to re-fetch headlines (seconds). Default: 5 minutes.
NEWS_REFRESH=300

# ── Volume spike detection ─────────────────────────────────────────────────────
# Set to false to disable volume/price-move signals
VOLUME_SPIKE_ENABLED=true
# Minimum ratio of current/previous volume to flag as a spike (1.5 = 50% increase)
VOLUME_SPIKE_THRESHOLD=1.5

# ── Fair value / external odds ─────────────────────────────────────────────────
# The Odds API key for sportsbook consensus odds comparison (free tier: 500 req/month)
# Sign up at https://the-odds-api.com — leave blank to use order book depth analysis only
ODDS_API_KEY=

# ── Backtest / performance tracking ───────────────────────────────────────────
# Minimum combined score to auto-log a signal for tracking (0–100).
# Lower = more picks tracked, higher = only high-conviction picks.
BACKTEST_MIN_SCORE=50
